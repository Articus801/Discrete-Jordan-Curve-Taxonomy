# deval.py - PVA with lazy + eager threshold

EAGER_THRESHOLD = 50 # reduce when tuple gets bigger than this

def phi(p):
    # Euler totient for prime p = p-1. We'll expand LUT later
    return p - 1

class PVA:
    def __init__(self, prime, exp=1):
        self.tuple = [(prime, exp)]

    def _reduce(self):
        # Combine same primes: (2,1)*(2,3) -> (2,4)
        d = {}
        for p, e in self.tuple:
            d[p] = d.get(p, 0) + e
        self.tuple = list(d.items())

    def __mul__(self, other):
        new = PVA(2, 0)
        new.tuple = self.tuple + other.tuple

        # Lazy by default, eager if too big
        if len(new.tuple) > EAGER_THRESHOLD:
            new._reduce() # this is where phi_n logic will go later

        return new

    def __len__(self):
        return len(self.tuple)

